    "brand_story_kjQ4fK": {
      "type": "brand-story",
      "name": "Brand Story",
      "settings": {
        "custom_class": "brand-story-default pt-80",
        "title": "Brand Story",
        "text": "\"Nature itself is the best physician.\" - Hippocrates",
        "list_content": "<p>Ancient Bliss was born from a deeply personal journey—one of healing, awakening, and a return to the wisdom of nature. Inspired by indigenous traditions and the transformative energy of Hawaii, we create herbal supplements that do more than support your health—they help you come home to yourself. Since 2021, over 350,000 people have experienced the power of our formulas, crafted with zero fillers, additives, or anything artificial. Just pure, potent herbs—chosen with care, made with purpose. At Ancient Bliss, we believe your body is sacred. Let nature lead, and let your wellness be as pure as your intention. <br/><br/>Inspired by Pele, the Hawaiian goddess of transformation, Ancient Bliss was created to ignite powerful change—guiding you to care for yourself with the purity and intention you deserve.<br/><br/></p>",
        "text_align": "left",
        "left_image": "shopify://shop_images/brand-story.webp",
        "left_image_alt": "Brand founder image",
        "right_image_top": "shopify://shop_images/radient-wellness.webp",
        "right_image_top_alt": "Supplement badge or logo",
        "right_image_bottom": "shopify://shop_images/capsules.webp",
        "right_image_bottom_alt": "Supplement capsule image"
      }
    },
    "image_banner_qqzEkL": {
      "type": "image-banner",
      "name": "Image Banner",
      "settings": {
        "custom_class": "nature_wisdom_section pt-80 mt-110",
        "bg_color": "rgba(0,0,0,0)",
        "right_side_image": "shopify://shop_images/nature-wisdome-img.webp",
        "useout_side": false,
        "useout_side_mob": false,
        "vertical_align": "align-middle",
        "horizontal_align": "align-center",
        "heading_line1": "Nature’s Wisdom in Every Dose",
        "description": "<p>At Ancient Bliss, we believe wellness begins with awareness. Our mission is to help you reconnect with your body’s natural wisdom, free from corporate-driven misinformation. Every formula is crafted with powerful herbs, rooted in indigenous knowledge, and backed by science — no fillers, no shortcuts. We preserve nature’s integrity to deliver supplements that truly support healing and transformation. These aren’t just capsules; they’re invitations to slow down, nourish yourself, and live in alignment. With each dose, you’re not just improving your health — you’re embracing a deeper, more intentional way of living.<br/><br/></p>",
        "button_text_1": "SHOP NOW",
        "button_url_1": "",
