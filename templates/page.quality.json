      "name": "Lab Testing Section",
      "settings": {
        "html_id": "",
        "custom_class": "mt-110",
        "heading": "Nothing to Hide. Everything to Trust.",
        "description": "At Ancient Bliss, we don’t take chances with your health. Every ingredient and every batch goes through rigorous testing to ensure purity, accuracy, and safety — because trust starts with transparency.\nWe test raw materials, in-process samples, and finished products, ensuring what’s on the label is exactly what’s in your bottle. Our controlled manufacturing environment keeps quality consistent at every step.",
        "subheading": "Our In-House Testing Includes",
        "desktop_image": "shopify://shop_images/quality-trust-img.webp",
        "mobile_image": "shopify://shop_images/mobile-quality-trust-img.webp",
        "image_alt": "Lab technicians testing plant samples in a laboratory"
      }
