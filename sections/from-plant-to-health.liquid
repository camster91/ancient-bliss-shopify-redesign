{% schema %}
{
  "name": "From Plant to Pillar",
  "tag": "section",
  "class": "plant-pillars-section-wraper",
  "settings": [
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "FROM PLANT TO PILLAR OF HEALTH"
    },
    {
      "type": "select",
      "id": "main_heading_alignment",
      "label": "Main Heading Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#e2d5f6"
    },
    {
      "type": "image_picker",
      "id": "background_image_left",
      "label": "Background Image - Left"
    },
    {
      "type": "image_picker",
      "id": "background_image_center",
      "label": "Background Image - Center"
    },
    {
      "type": "image_picker",
      "id": "background_image_right",
      "label": "Background Image - Right"
    },
	{
  "type": "text",
  "id": "button_label",
  "label": "Button Label",
  "default": "Learn More"
},
{
  "type": "url",
  "id": "button_link",
  "label": "Button Link"
},
  {
      "type": "text",
      "id": "custom_id",
      "label": "Custom HTML ID (optional)"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom HTML Class (optional)"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "icon_alt",
          "label": "Icon Alt Text",
          "default": "Feature icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Handpicked Herbs"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Research based on organic ingredients."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "From Plant to Pillar"
    }
  ]
}
{% endschema %}

{% stylesheet %}
.plant-pillars-section {
	position: relative;
	padding: 0px 0 0;
	overflow: hidden;
	background: #A33C3F;
}


.plant-pillars-backgrounds {
	position: unset;
	top: 0;
	left: 0;
	z-index: 0;
	width: 100%;
	height: 100%;
	display: flex;
	justify-content: space-between;
	align-items: first baseline;
	pointer-events: none;
	padding: 50px 0 0;
	background-image: url("https://cdn.shopify.com/s/files/1/0618/4543/8615/files/grid-bg.webp?v=1755092399");
	background-size: 100%;
	background-repeat: no-repeat;
	background-position: center bottom -190px;
}

  .plant-pillars-backgrounds .bg-img {
    max-height: 100%;
    object-fit: contain;
    width: auto;
    height: auto;
    max-width: 33%;
  }


  .plant-pillars-inner {
    position: relative;
    z-index: 1;
    max-width: 1270px;
    margin: 0 auto;
    padding-left: 15px;
    padding-right: 15px;
  }

  .plant-pillars-section .plant-pillars-inner {
    position: unset;
    top: 0%;
    left: 0;
    right: 0;
    margin: auto;
    padding-top: 85px;
  }

.plant-pillars-section .plant-pillars-inner h2 {
	font-size: 56px;
	margin-bottom: 60px;
	color: #fff;
	padding-top: 0;
	line-height: 100%;
	letter-spacing: -0.2px;
}
.pillars-features {
	display: flex;
	justify-content: space-between;
	gap: 10px;
	flex-wrap: wrap;
	margin-bottom: 0;
	z-index: 9;
	align-items: center;
	position: relative;
}

.pillars-features::before {
	position: absolute;
	content: "";
	background: rgba(255, 255, 255, 0.1);
	width: 100%;
	height: 5px;
	border-radius: 30px;
	max-width: 870px;
	margin: 0 auto;
	left: 0;
	right: 0;
	z-index: -1;
	top: 62px;
	opacity: 1;
}

.pillars-feature {
	max-width: calc(33.3% - 7.5px);
	background: transparent;
	border-radius: 16px;
	padding: 24px 18px;
	text-align: left;
}

 .pillars-feature img {
