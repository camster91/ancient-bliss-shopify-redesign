<div
  class="plant-pillars-section {{ section.settings.custom_class }}"
  id="{{ section.settings.custom_id }}"
  style="--bg-color: {{ section.settings.background_color }};"
>
    <div class="plant-pillars-inner">
    <h2 style="text-align: {{ section.settings.main_heading_alignment }};">
      {{ section.settings.main_heading }}
    </h2>

    <div class="pillars-features">
      {% for block in section.blocks %}
        <div class="pillars-feature">
          {% if block.settings.icon %}
           <span class="icon-holder"> <img
              src="{{ block.settings.icon | image_url: width: 64 }}"
              alt="{{ block.settings.icon_alt | escape }}"
            ></span>
          {% endif %}
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
  
  {% if section.settings.button_label != blank and section.settings.button_link != blank %}
  <div class="pillars-button-wrap" style="text-align: {{ section.settings.main_heading_alignment }};">
    {% comment %} <a href="{{ section.settings.button_link }}" class="pillars-btn">
      {{ section.settings.button_label }}
    </a> {% endcomment %}
	<a href="{{ section.settings.button_link }}" class="btn gradient-theme slideshow__btn slideshow__btn{{block.id}} image_content_btn {%if section.settings.stylebtns == 'default' %} btn-theme {% elsif section.settings.stylebtns == 'underline' %}  btn-underline {% else %} btn-before {% endif %}">
                  {{ section.settings.button_label | escape }}
                </a>
  </div>
{% endif %}

  <div class="plant-pillars-backgrounds">
    {% if section.settings.background_image_left %}
      <img class="bg-img left" src="{{ section.settings.background_image_left | image_url: width: 600 }}" alt="">
    {% endif %}
    {% if section.settings.background_image_center %}
      <img class="bg-img center" src="{{ section.settings.background_image_center | image_url: width: 800 }}" alt="">
    {% endif %}
    {% if section.settings.background_image_right %}
      <img class="bg-img right" src="{{ section.settings.background_image_right | image_url: width: 600 }}" alt="">
    {% endif %}
  </div>


</section>
