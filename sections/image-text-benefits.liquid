{% schema %}
{
  "name": "Vital Systems Support",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text",
      "default": "Healthy lifestyle support"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "An Effective Support to Vital Systems!"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS Class"
    },
    {
      "type": "text",
      "id": "custom_id",
      "label": "Custom Section ID"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image Position",
      "options": [
        {
          "value": "left",
          "label": "Image Left, Text Right"
        },
        {
          "value": "right",
          "label": "Image Right, Text Left"
        }
      ],
      "default": "left"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "benefit_text",
          "label": "Benefit Text",
          "default": "Lowers Insulin Levels"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vital Systems Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<section 
  id="{{ section.settings.custom_id | escape }}" 
  class="vital-systems-section {{ section.settings.custom_class }} layout-{{ section.settings.layout }}">
  <div class="container">
    <div class="vital-grid">
      
      {% if section.settings.layout == 'left' %}
        <div class="vital-image">
          {% if section.settings.image %}
            <img src="{{ section.settings.image | img_url: '800x' }}" 
                 alt="{{ section.settings.image_alt | escape }}">
          {% endif %}
        </div>
        <div class="vital-content">
          <h2>{{ section.settings.heading }}</h2>
          <ul class="vital-list">
            {% for block in section.blocks %}
              <li class="vital-item">
                <span class="checkmark">✔</span> {{ block.settings.benefit_text }}
              </li>
            {% endfor %}
          </ul>
        </div>
      
      {% else %}
        <div class="vital-content">
          <h2>{{ section.settings.heading }}</h2>
          <ul class="vital-list">
            {% for block in section.blocks %}
              <li class="vital-item">
                <span class="checkmark">✔</span> {{ block.settings.benefit_text }}
              </li>
            {% endfor %}
          </ul>
        </div>
        <div class="vital-image">
          {% if section.settings.image %}
            <img src="{{ section.settings.image | img_url: '800x' }}" 
                 alt="{{ section.settings.image_alt | escape }}">
          {% endif %}
        </div>
      {% endif %}

    </div>
  </div>
</section>

<style>
.vital-systems-section {
  padding: 50px 20px;
}
.vital-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: center;
}
.vital-image img {
  width: 100%;
  height: auto;
  border-radius: 12px;
}
.vital-content h2 {
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 20px;
}
.vital-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px 30px;
}
.vital-item {
  font-size: 16px;
  display: flex;
  align-items: center;
}
.vital-item .checkmark {
  color: #006400;
  margin-right: 8px;
}
@media(max-width: 768px) {
  .vital-grid {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .vital-list {
    grid-template-columns: 1fr;
  }
}
</style>
