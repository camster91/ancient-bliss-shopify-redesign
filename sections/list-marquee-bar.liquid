<!-- List Marquee Bar start -->
<section class="list-marquee-bar">
  <div class="list-marquee-wrap">
    <div class="list-marquee-track">
      {% for block in section.blocks %}
        {% if block.settings.single_list_text != blank %}
          <div class="list-text" style="color:{{ block.settings.single_list_text_color }};">
            <span>&#10003;</span> {{ block.settings.single_list_text }}
          </div>
        {% endif %}
      {% endfor %}

      <!-- Duplicate content for seamless infinite scroll -->
      {% for block in section.blocks %}
        {% if block.settings.single_list_text != blank %}
          <div class="list-text" style="color:{{ block.settings.single_list_text_color }};">
            <span>&#10003;</span> {{ block.settings.single_list_text }}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "List Marquee Bar",
  "settings": [
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "paragraph",
      "content": "Desktop / Laptop "
    },
    {
      "type": "range",
      "id": "brand_padding_top",
      "label": "Section Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "brand_padding_bottom",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 100
    },
    {
      "type": "paragraph",
      "content": "Tablet"
    },
    {
      "type": "range",
      "id": "brand_padding_top_lg",
      "label": "Section Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "brand_padding_bottom_lg",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "paragraph",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "brand_padding_top_xs",
      "label": "Section Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "brand_padding_bottom_xs",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Background Color"
    },
    {
      "type": "checkbox",
      "id": "brand_check",
      "label": "With Background",
      "default": true
    },
    {
      "type": "color",
      "id": "brand_bgcolor",
      "label": "Background Color",
      "default": "#28262d"
    }
  ],
  "blocks": [
    {
      "type": "list_text",
      "name": "Single List Text",
      "settings": [
        {
          "type": "text",
          "id": "single_list_text",
          "label": "List Text",
          "default": "Made In USA"
        },
        {
          "type": "color",
          "id": "single_list_text_color",
          "label": "List Text Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "List Marquee Bar",
      "category": "List Marquee Bar"
    }
  ]
}
{% endschema %}

<style>
.list-marquee-bar {
  overflow: hidden;
  position: relative;
  white-space: nowrap;
  {% if section.settings.brand_check %}
  background-color: {{ section.settings.brand_bgcolor }};
  {% endif %}
  padding-top: {{ section.settings.brand_padding_top }}px;
  padding-bottom: {{ section.settings.brand_padding_bottom }}px;
}





.list-marquee-wrap {
  display: flex;
  align-items: center;
  width: 100%;
  overflow: hidden;
}

.list-marquee-track {
  display: inline-block;
  white-space: nowrap;
  animation: marquee 30s linear infinite;
}

.list-text {
	display: inline-block;
	padding: 17.6px 50px;
	font-size: 24px;
	text-transform: uppercase;
	line-height: 1.2;
}
.list-text > span {
	margin-right: 15%;
} 

@keyframes marquee {
  0% {
    transform: translateX(0%);
  }
  100% {
    transform: translateX(-50%);
  }
}

@media (max-width: 1199px){
  .list-marquee-bar {
    padding-top: {{ section.settings.brand_padding_top_lg }}px;
    padding-bottom: {{ section.settings.brand_padding_bottom_lg }}px;
  }
}
  @media (max-width: 767px){
  .list-marquee-bar {
    padding-top: {{ section.settings.brand_padding_top_xs }}px;
    padding-bottom: {{ section.settings.brand_padding_bottom_xs }}px;
  }
  .list-marquee-bar .list-text {
	display: inline-block;
	padding: 0 15px;
	font-size: 16px;
	text-transform: uppercase;
	line-height: 1.2;
}
}
</style>
