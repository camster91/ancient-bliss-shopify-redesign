{% assign tag = section.settings.text_tag %}

<section class="inspired-nature-block {{ section.settings.custom_class }}">
  <div class="container">

    <!-- Top Split Content (Left: heading, Right: paragraph) -->
    <div class="split-text-top">
      <div class="left">
        <{{ tag }} class="main-heading">
          {{ section.settings.left_heading }}
        </{{ tag }}>
      </div>
      <div class="right">
        {{ section.settings.main_text }}
      </div>
    </div>

    <!-- Responsive Image -->
    <div class="image-block">
      <picture>
        {% if section.settings.mobile_image %}
          <source media="(max-width: 767px)" srcset="{{ section.settings.mobile_image | image_url }}">
        {% endif %}
        {% if section.settings.desktop_image %}
          <img
            src="{{ section.settings.desktop_image | image_url }}"
            alt="{{ section.settings.image_alt | escape }}"
            loading="lazy"
            class="responsive-img"
          >
        {% endif %}
      </picture>
    </div>

    <!-- Bottom Split Content -->
    <div class="split-text-bottom">
      <div class="bottom-left">
        {{ section.settings.bottom_left }}
      </div>
      <div class="bottom-right">
        {{ section.settings.bottom_right }}
      </div>
    </div>

  </div>
</section>

<style>
.inspired-nature-block {
  padding: 60px 20px;
  background: #fff;
}

.split-text-top, .split-text-bottom {
	display: flex;
	gap: 30px;
	margin-bottom: 30px;
	align-items: center;
}
.split-text-top .left,
.split-text-top .right,
.split-text-bottom .bottom-left,
.split-text-bottom .bottom-right {
  flex: 1 1 50%;
  min-width: 280px;
}
.split-text-top .main-heading {
  font-size: 2rem;
  font-weight: bold;
  line-height: 1.4;
}

.image-block {
  margin: 30px 0;
}
.responsive-img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 8px;
}

.inspired-nature-block .split-text-top .left .main-heading p {
	font-size: 56px;
	line-height: normal;
	font-family: Butler;
	line-height: 100%;
}
 
.inspired-nature-block .split-text-bottom .bottom-right p {
	font-size: 18px;
	color: rgba(24,27,27,0.8);
	letter-spacing: -0.1px;
} 



 
@media (max-width: 1024px) {
  .split-text-top,
  .split-text-bottom {
    flex-direction: column;
  }
  .split-text-top .main-heading {
    font-size: 1.5rem;
  }
  .inspired-nature-block .split-text-top .left .main-heading p {
	font-size: 32px;
}
.split-text-top .left, .split-text-top .right, .split-text-bottom .bottom-left, .split-text-bottom .bottom-right {
	flex: 1 1 100%;
	min-width: 100%;
}
.inspired-nature-block .split-text-bottom .bottom-right p {
	font-size: 16px;
}
.split-text-top, .split-text-bottom {
	gap: 15px;
}

  
}
</style>

{% schema %}
{
  "name": "Inspired by Nature",
  "tag": "section",
  "class": "section-inspired-nature",
  "settings": [
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS Class",
      "default": "custom_class"
    },
    {
      "type": "select",
      "id": "text_tag",
      "label": "Heading Tag",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "p",  "label": "Paragraph" },
        { "value": "ul", "label": "Unordered List" }
      ]
    },
    {
      "type": "richtext",
      "id": "left_heading",
      "label": "Left Heading",
      "default": "<p><strong>Inspired by Nature.<br>Guided by Tradition.</strong></p>"
    },
    {
      "type": "richtext",
      "id": "main_text",
      "label": "Right Paragraph",
      "default": "<p><strong>Founded in 2021,</strong> Ancient Bliss was born from a simple but powerful revelation...</p>"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Banner Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Banner Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image Alt Text"
    },
    {
      "type": "richtext",
      "id": "bottom_left",
      "label": "Bottom Left Text",
      "default": "<p>Macy Schuchart’s journey began during a transformative six-month stay in Hawaii...</p>"
    },
    {
      "type": "richtext",
      "id": "bottom_right",
      "label": "Bottom Right Text",
      "default": "<p>That wisdom led her to launch a brand centered on purity and potency, inspired by Pele...</p>"
    }
  ],
  "presets": [
    {
      "name": "Inspired by Nature Block"
    }
  ]
}
{% endschema %}
