<!--  start  -->
<form action="/search" method="get" role="search" class="bg-blog">
    <input type="hidden" name="type" value="article" />
    <div class="input-group--underline search-blog">
      <input class="input-group__field search-blogs" type="search" name="q" value="{{ search.terms | escape }}" placeholder=" Search Blogs" aria-label="{{ 'general.search.placeholder' | t }}">
     <div class="input-group__btn blog-btn">
        <button type="submit" class="btn btn--clear btn--square">
          {% include 'icon-search' %}
          <span class="icon__fallback-text">{{ 'general.search.submit' | t }}</span>
        </button>
      </div>
    </div>
  </form>
<!--  end  -->


<div class="row tag-top">
 {%- if settings.sidebar_tag -%}
    <div class="content-block content-block--small">
      <h6 class="sidebar__title">{{ 'blogs.article.tags' | t }}</h6>
      <ul class="list-unstyled list-blog-tags clearfix mb-0">
        <li class="list_li">
         <div class="btn-new"> <a href="{{ blog.url }}">{{ 'blogs.article.all_tags' | t }}</a></div>
        </li>
        {%- for tag in blog.all_tags -%}
        {%- if current_tags contains tag -%}
        <li>{{ tag }}</li>
        {%- else -%}
        <li class="list_li"><div class="btn-new"> {{ tag | link_to_tag: tag }}</div></li>
        {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
    {%- endif -%}
</div>

  
  <div class="row {% if section.settings.sidebar_position == 'left' %}flex-row-reverse{% endif %}">
    {%- assign limit = section.settings.limit | minus:1 -%}
    {%- paginate blog.articles by limit -%}
    <div class="{% if section.settings.sidebar_enable %}col-md-9 {% if section.settings.sidebar_position == 'left' %} pl-lg-5{% else %} pr-lg-5{% endif %} {% else %}col-12{% endif %}">
      <div class="row">
        {%- for article in blog.articles -%}
        <div class="{{col}} {% if forloop.index == 3 %}col--last{% endif %}">
          {%- include 'blog-card' -%}
        </div>
        {%- endfor -%}
      </div>
      {%- if paginate.pages > 1 -%}
      <div class="pagination">
        {{ paginate | default_pagination | replace: '&laquo; Previous', '&larr;' | replace: 'Next &raquo;', '&rarr;' }}
      </div>
      {%- endif -%}
    </div>
    {%- endpaginate -%}
    {%- if section.settings.sidebar_enable -%}
    {%- include 'blogSidebar' -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
  {
    "name": "blog",
    "settings": [
      {
        "type": "range",
        "id": "limit",
        "min": 6,
        "max": 50,
        "step": 1,
        "label": "Limit",
        "default": 8
      },
      {
        "type": "header",
        "content": "Sidebar"
      },
      {
        "type": "checkbox",
        "id": "sidebar_enable",
        "label": "Enable",
		"default": true
      },
      {
        "type": "select",
        "id": "sidebar_position",
        "label": "Position",
        "default": "right",
        "options": [
          {
            "value": "left",
            "label": "Left"
          },
          {
            "value": "right",
            "label": "Right"
          }
        ]
      }
]
  }
{% endschema %}