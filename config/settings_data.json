      "page-about": {
        "type": "page-about",
        "settings": {
          "intro_enable": true,
          "intro_title": "Our story",
          "intro_des": "<p>The <a href=\"https://ap2020.myshopify.com\">2020</a> story started over a coffee at one of our favourite cafes – Nooks in Randwick, Sydney in early 2013. Sitting there looking at all the mums, bubs, Shopify theme and prams we started thinking… Shopify theme and prams all look the same… black, maybe a little red here and there, very few had any colour or excitement. We thought – what alternatives are there for Australian mums and dads that a stroller that is functional, modern and at an affordable price? Most stroller brands come from the US or Europe but what about a local Australian brand?</p>\n<p>We searched far and wide and everywhere in between and couldn’t find any options that were functional, modern, Australian owned and at an affordable price. Surprisingly, we couldn’t even find any Shopify theme or prams that were designed to comply with the latest Australian safety standards.</p>",
          "intro_background": "",
          "intro_image": "",
          "achie_enable": true,
          "achie_title": "Fun fact",
