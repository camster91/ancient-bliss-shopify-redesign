      "page-faqs": {
        "type": "page-faqs",
        "blocks": {
          "1562290842379": {
            "type": "faq",
            "settings": {
              "title": "Are Ancient Bliss products Organic?",
              "answer": "Yes. Ancient Bliss uses organic ingredients in all our products."
            }
          },
          "1562290853274": {
            "type": "faq",
            "settings": {
              "title": "Are your supplements manufactured in the USA?",
              "answer": "All Ancient Bliss supplements are manufactured in the USA, in an FDA registered, approved, and inspected state-of-the-art facility located in the state of Georgia."
            }
          },
          "1563634068295": {
            "type": "faq",
            "settings": {
              "title": "Are your products GMP certified?",
              "answer": "Our products are GMP certified. It provides for systems that assure proper design, monitoring, and control of manufacturing processes and facilities. GMPs are enforced in the United States by the U.S. Food and Drug Administration."
            }
          },
          "1562290837129": {
            "type": "faq",
            "settings": {
              "title": "Are your products FDA approved?",
              "answer": "FDA does not approve dietary supplements. However, the FDA does regulate both dietary supplements and dietary ingredients. We follow the FDA guidelines for “Current Good Manufacturing Practice” which are established regulations requiring that manufacturers test and evaluate all products for identity, purity, composition and strength."
            }
          },
          "1563634113380": {
            "type": "faq",
            "settings": {
              "title": "Are your supplements hypoallergenic?",
              "answer": "Ancient Bliss strives to purchase the highest quality ingredients, and we never use ingredients that contain hidden allergens."
            }
          },
          "1563634164478": {
            "type": "faq",
            "settings": {
              "title": "Are your supplements Vegan?",
              "answer": "Yes. They are made from a vegetable capsule instead of Gelatin. Ancient Bliss will also never support the laboratory testing of animals."
            }
          },
          "1563634197538": {
            "type": "faq",
            "settings": {
              "title": "Are Ancient Bliss products certified Organic?",
              "answer": "Yes. Ancient Bliss is certified organic by the Midwest Organic Services Association (MOSA)"
            }
          },
          "1563634219217": {
            "type": "faq",
            "settings": {
              "title": "What is Ancient Bliss’s policy on GMO’S?",
              "answer": "Ancient bliss is committed to using and supporting only non-GMO materials. We do not purchase GMO herbs and/or ingredients."
            }
          },
          "1563634284948": {
            "type": "faq",
            "settings": {
              "title": "Can I consume multiple supplements at the same time?",
              "answer": "Yes, all supplements can be consumed at the same time. In fact, many synergize extremely well together (or activate certain compounds that strengthen the healing powers in each other)"
            }
          },
          "1563634717303": {
            "type": "faq",
            "settings": {
              "title": "Are your supplements safe to take with any medication?",
              "answer": "Individuals with a known medical condition should consult a physician before using this or any dietary supplement."
            }
          },
          "1563634745197": {
            "type": "faq",
            "settings": {
              "title": "Can I take more than what is recommended on the label?",
              "answer": "It is recommended to follow the directions as stated on the product label. If you feel the need to take more than what is recommended, we suggest you consult with your physician first."
            }
          },
          "1563634758436": {
            "type": "faq",
            "settings": {
              "title": "What is the best way to store my supplements?",
              "answer": "We recommend for them to be stored tightly sealed in a cool, dry place, such as a cabinet or in a pantry."
            }
          },
          "1563634530941": {
            "type": "faq",
            "disabled": true,
            "settings": {
              "title": "Do you offer information and coaching on living a healthy lifestyle?",
              "answer": "We will soon be offering guidance and coaching in experiencing a connected life experience: mind, body, and spirit, and working with your individual health concerns. Join\nthe tribe (Insert link here to sign up for newsletter) to stay connected and stay tuned for future updates!"
            }
          },
          "7ea684fd-ed8e-442e-9d53-c024d7f585c7": {
            "type": "faq",
            "disabled": true,
            "settings": {
              "title": "Don’t see your question here?",
              "answer": "You can contact us through our contact page (https://join.collabs.shopify.com/community/apply/iDCa4TJBzdI) with any questions you might have and we will be happy to help!"
            }
          },
          "7068e373-f28f-41cc-9ecc-39ff5fa3b78d": {
            "type": "faq",
            "disabled": true,
            "settings": {
              "title": "Do you offer information and coaching on living a healthy lifestyle?",
