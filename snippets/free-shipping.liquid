{%- if settings.free_shipping_enable -%}
{% assign free_shipping_threshold = settings.free_shipping_value | times: 100 %}
{% assign cart_total = cart.total_price %}
{% assign percentage = cart_total | times: 100 | divided_by: free_shipping_threshold %}
{% if percentage > 100 %}{% assign percentage = 100 %}{% endif %}

<div class="free-shipping-wrapper" style="margin: 20px 0; padding: 15px; border: 1px solid #e1e1e1; border-radius: 8px; background-color: #f9f9f9;">
  <p class="free-shipping-text" style="text-align: center; margin-bottom: 12px; font-weight: 600; color: #333;">
    {% if cart_total < free_shipping_threshold %}
      {% assign remaining = free_shipping_threshold | minus: cart_total %}
      You're only <strong>{{ remaining | money }}</strong> away from <span style="color: #28a745;">FREE Shipping!</span>
    {% else %}
      🎉 <span style="color: #28a745;">You've unlocked FREE Shipping!</span>
    {% endif %}
  </p>
  <div class="progress" style="height: 12px; background-color: #eee; border-radius: 6px; overflow: hidden; box-shadow: inset 0 1px 2px rgba(0,0,0,0.1);">
    <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: {{ percentage }}%; height: 100%; background: linear-gradient(90deg, #28a745, #5cd85c); transition: width 0.5s ease;" aria-valuenow="{{ percentage }}" aria-valuemin="0" aria-valuemax="100"></div>
  </div>
</div>
{%- endif -%}