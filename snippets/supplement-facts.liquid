<div class="supplement-facts-accordion" style="margin-top: 20px; border-top: 1px solid #ddd; padding-top: 10px;">
  <details>
    <summary style="font-weight: bold; cursor: pointer; list-style: none; display: flex; justify-content: space-between;">
      Supplement Facts & Dosages
      <span class="icon-plus">+</span>
    </summary>
    <div class="supplement-facts-content" style="padding-top: 10px; font-size: 0.9em; color: #555;">
      <p><em>Exact dosages and daily values will populate here based on the product meta-fields.</em></p>
      <!-- Example Image Placeholder -->
      <img src="{{ 'supplement-facts-placeholder.jpg' | asset_url }}" alt="Supplement Facts" style="max-width: 100%; border: 1px solid #eee; margin-top: 10px;" onerror="this.style.display='none'">
    </div>
  </details>
</div>
