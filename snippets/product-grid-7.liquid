<!-- product-grid-7.liquid -->
<div class="product-card js-product-card product-card--style7" data-price="{{ product.price }}" >
    <div class="product-card__image-wr overflow-hidden">
      {%- assign image = product.featured_image -%}
      <a class="product-card__image js image-content__image-wrapper" href="{{ product.url | within: collection }}" style="max-width: 680px;padding-top:{{ 1 | divided_by: image.aspect_ratio | times: 100}}%;" data-image-id="{{ image.id }}">
        {%- assign img_url = image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
        <img class="lazyload transition first-image"
             data-src="{{ img_url }}"
             src="{%- include 'srcBlank' -%}"
             data-sizes="auto"
             alt="{{ image.alt | escape }}"
             loading="lazy"
             width="{{ image.width }}"
             height="{{ image.height }}">
             {% include 'second-image'%}
      </a>
  
      <div class="product-card__overlay d-flex justify-content-center flex-column">
        {%- if settings.enable_wishlsit -%}
      <span data-toggle="tooltip" data-placement="left" data-tooltipalltimes="true" class="btn btn-theme gradient-theme-vertical product-card__overlay-btn js-btn-wishlist" title="{{ 'products.product.wishlist_text' | t }}" data-handle="{{product.handle}}">
        {%- include 'icon-heart' -%}
      </span>
      {%- endif -%}

      {%- if settings.enable_compare -%}
      <span data-tooltip="true" data-placement="left" class="btn btn-theme gradient-theme-vertical product-card__overlay-btn js-btn-compare" title="{{ 'products.product.compare_text' | t }}" data-handle="{{product.handle}}">
        {%- include 'icon-exchange' -%}
        {%- include 'icon-close' -%}
        <span>{{ 'products.product.compare_text' | t }}</span>
      </span>
      {%- endif -%}
      
      </div>
      {%- if settings.qv_box -%}
      <span  class="btn btn-theme gradient-theme-vertical js-btn-quickview" data-toggle="modal" data-target="#jsQuickview" data-handle="{{product.handle}}" data-pavailable="{% if product.available %}true{% else %}false{% endif %}">
        <span>{{ 'products.product.quickview_text' | t }}</span>
        {% if product.metafields.info.shortdesc != blank %}
          <span class=" txt-short hide" >
            {{product.metafields.info.shortdesc | strip_html | truncatewords: 12 }}
          </span>
        {%- endif -%}
      </span>
      {%- endif -%}
  
      {%- if settings.enable_countdown_card -%}{%- include 'product-countdown' -%}{%- endif -%}
  
      {%- if settings.enablevideo -%}
      {% for media in product.media %}
      {% render 'productVideo', media: media %}
    {% endfor %}
      {%- endif -%}
  
      {% include 'product-label' %}
    </div>
    <div class="product-card__info  {% unless product.available %} disabled{% endunless %}">
      {%- if settings.enable_type -%}
      <div class="text-uppercase small mb-2 gift" style="opacity: 0.8;">{{ product.type }}</div>
      {%- endif -%}
      <a href="{{ product.url | within: collection }}" title="{{product.title}}" class="product-card__name d-block">
  <div class="product-tab-cards" style="display: flex; gap: 8px; flex-wrap: wrap;">
     <div class="cards-product-title">
      {{ product.title }}
    </div> 
    {% comment %} <div class="product-card__price font-family-1" style="font-weight: bold;">
      {{ product.price | money }}
    </div>
    {% endcomment %}

    <div class="product-card__price font-family-1" style="font-weight: bold;">
  {% if product.compare_at_price > product.price %}
    <span class="product-card__price--compare" style="text-decoration: line-through; color: #888;">
      {{ product.compare_at_price | money }}
    </span>
    <span class="product-card__price--sale" style="color: #d00; margin-left: 5px;">
      {{ product.price | money }}
    </span>
  {% else %}
    <span class="product-card__price--regular">
      {{ product.price | money }}
    </span>
  {% endif %}
</div>

  </div>
</a>

        
      {%- include 'swatch-grid-1' -%}
      <!-- NEW CONTENT BELOW -->

      <!-- Price before Title -->
{% comment %} <div style="margin-bottom: 8px;">
    <h3 class="product-title" style="display: inline-block; font-size: 16px; margin: 0;">
    {{ product.title }}
  </h3>

  <div class="product-price" style="font-weight: bold; display: inline-block; margin-right: 8px;">
    {{ product.price | money }}
  </div>

</div> {% endcomment %}

<!-- Star Rating -->
<div class="product-rating" style="font-size:14px; color: #FFA500; margin-top: 5px;">
  {% comment %} ⭐️⭐️⭐️⭐️⭐️ <span>4.8</span> {% endcomment %}
<!-- Start of Judge.me code --> 
  <div class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}'> 
    {{ product.metafields.judgeme.badge }} 
  </div> 
<!-- End of Judge.me code -->
</div>

