<!-- Add to Cart Button -->
<form method="post" action="/cart/add" style="margin-top: 10px;">
  <input type="hidden" name="id" value="{{ product.variants.first.id }}">
  <button type="submit" class="btn btn-theme gradient-theme-vertical" style="width: 100%;">
    Add to Cart
  </button>
</form>
      
      
